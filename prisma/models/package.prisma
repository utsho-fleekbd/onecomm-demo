// =======================
// Enums
// =======================

enum PackageBillingCycle {
  FREE
  MONTHLY
  YEARLY
  LIFETIME
}

enum PackageStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum PackageResetCycle {
  LIFETIME
  DAILY
  MONTHLY
  YEARLY
}

enum PackageLimitKey {
  MAX_TAGS       @map("max_tags")
  MAX_UNITS      @map("max_units")
  MAX_ROLES      @map("max_roles")
  MAX_MEDIAS     @map("max_medias")
  MAX_BRANDS     @map("max_brands")
  MAX_PRODUCTS   @map("max_products")
  MAX_VARIANTS   @map("max_variants")
  MAX_EMPLOYEES  @map("max_employees")
  MAX_ATTRIBUTES @map("max_attributes")
  MAX_BUSINESSES @map("max_businesses")
  MAX_CATEGORIES @map("max_categories")
}

enum PackageSubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum PackagePaymentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  EXPIRED
}

enum PackagePaymentType {
  PLAN_CHANGE
}

// =======================
// Models
// =======================

model PackagePlan {
  id            String              @id @default(uuid()) @db.Uuid
  name          String              @db.VarChar(150)
  description   String?
  price         Decimal             @default(0) @db.Decimal(12, 2)
  billingCycle  PackageBillingCycle @map("billing_cycle")
  currencyCode  String              @default("BDT") @map("currency_code") @db.VarChar(10)
  freeTrialDays Int                 @default(0) @map("free_trial_days")
  isDefault     Boolean             @default(false) @map("is_default")
  status        PackageStatus       @default(ACTIVE)
  sortOrder     Int                 @default(0) @map("sort_order")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")
  deletedAt     DateTime?           @map("deleted_at")

  limits        PackagePlanLimit[]
  features      PackagePlanFeature[]
  subscriptions PackageSubscription[]
  mockPayments  PackageMockPayment[]

  @@unique([name])
  @@index([isDefault])
  @@index([status])
  @@map("package_plans")
}

model PackagePlanFeature {
  id          String   @id @default(uuid()) @db.Uuid
  packageId   String   @map("package_id") @db.Uuid
  title       String   @db.VarChar(255)
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  package PackagePlan @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId])
  @@index([packageId, sortOrder])
  @@index([isActive])
  @@map("package_plan_features")
}

model PackagePlanLimit {
  id          String            @id @default(uuid()) @db.Uuid
  packageId   String            @map("package_id") @db.Uuid
  limitKey    PackageLimitKey   @map("limit_key")
  limitValue  Int               @map("limit_value")
  resetCycle  PackageResetCycle @default(LIFETIME) @map("reset_cycle")
  description String?
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  package PackagePlan @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@unique([packageId, limitKey])
  @@index([limitKey])
  @@map("package_plan_limits")
}

model PackageSubscription {
  id                 String                    @id @default(uuid()) @db.Uuid
  tenantId           String                    @map("tenant_id") @db.Uuid
  packageId          String                    @map("package_id") @db.Uuid
  planSnapshot       Json?                     @map("plan_snapshot")
  status             PackageSubscriptionStatus @default(TRIALING)
  billingCycle       PackageBillingCycle       @map("billing_cycle")
  price              Decimal                   @default(0) @db.Decimal(12, 2)
  currencyCode       String                    @default("BDT") @map("currency_code") @db.VarChar(10)
  startedAt          DateTime                  @map("started_at")
  trialEndsAt        DateTime?                 @map("trial_ends_at")
  currentPeriodStart DateTime                  @map("current_period_start")
  currentPeriodEnd   DateTime                  @map("current_period_end")
  endedAt            DateTime?                 @map("ended_at")
  endReason          String?                   @map("end_reason")
  autoRenew          Boolean                   @default(true) @map("auto_renew")
  createdAt          DateTime                  @default(now()) @map("created_at")
  updatedAt          DateTime                  @updatedAt @map("updated_at")

  package       PackagePlan           @relation(fields: [packageId], references: [id])
  tenant        SystemUser            @relation("TenantPackageSubscriptions", fields: [tenantId], references: [id], onDelete: Cascade)
  usageCounters PackageUsageCounter[]
  mockPayments  PackageMockPayment[]

  @@index([tenantId])
  @@index([packageId])
  @@index([status])
  @@index([currentPeriodEnd])
  @@map("package_subscriptions")
}

model PackageUsageCounter {
  id             String          @id @default(uuid()) @db.Uuid
  subscriptionId String          @map("subscription_id") @db.Uuid
  limitKey       PackageLimitKey @map("limit_key")
  usedValue      Int             @default(0) @map("used_value")
  periodStart    DateTime        @map("period_start")
  periodEnd      DateTime        @map("period_end")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  subscription PackageSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, limitKey, periodStart, periodEnd])
  @@index([limitKey])
  @@index([periodStart, periodEnd])
  @@map("package_usage_counters")
}

model PackageMockPayment {
  id             String               @id @default(uuid()) @db.Uuid
  tenantId       String               @map("tenant_id") @db.Uuid
  subscriptionId String?              @map("subscription_id") @db.Uuid
  planId         String?              @map("plan_id") @db.Uuid
  type           PackagePaymentType
  status         PackagePaymentStatus @default(PENDING)
  amount         Decimal              @default(0) @db.Decimal(12, 2)
  currencyCode   String               @default("BDT") @map("currency_code") @db.VarChar(10)
  metadata       Json?
  expiresAt      DateTime             @map("expires_at")
  confirmedAt    DateTime?            @map("confirmed_at")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  tenant       SystemUser           @relation("TenantPackageMockPayments", fields: [tenantId], references: [id], onDelete: Cascade)
  subscription PackageSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  plan         PackagePlan?         @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([subscriptionId])
  @@index([planId])
  @@index([status])
  @@index([expiresAt])
  @@map("package_mock_payments")
}
