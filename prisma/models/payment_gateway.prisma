// ======================================================
// ENUMS
// ======================================================

enum PaymentGatewayStatus {
  ACTIVE
  INACTIVE
}

enum PaymentGatewayMode {
  SANDBOX
  LIVE
}

enum PaymentGatewayConfigStatus {
  ACTIVE
  INACTIVE
}

enum PaymentMethodType {
  CASH
  COD
  ONLINE
  BANK_TRANSFER
  CARD
  MOBILE_BANKING
  OTHER
}

enum PaymentMethodStatus {
  ACTIVE
  INACTIVE
}

enum PaymentWebhookStatus {
  PENDING
  PROCESSED
  FAILED
  IGNORED
}

// ======================================================
// Models
// ======================================================

model PaymentGateway {
  id          String               @id @default(uuid()) @db.Uuid

  name        String               @db.VarChar(150)
  code        String               @db.VarChar(100)
  description String?
  status      PaymentGatewayStatus @default(ACTIVE)
  sortOrder   Int                  @default(0) @map("sort_order")

  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")

  configs     PaymentGatewayConfig[]
  methods     PaymentMethod[]
  webhooks    PaymentWebhookEvent[]

  @@unique([code])
  @@index([status])
  @@map("payment_gateways")
}

model PaymentGatewayConfig {
  id          String                     @id @default(uuid()) @db.Uuid
  businessId  String                     @map("business_id") @db.Uuid
  gatewayId   String                     @map("gateway_id") @db.Uuid

  configData  Json                       @map("config_data")
  mode        PaymentGatewayMode         @default(SANDBOX)
  status      PaymentGatewayConfigStatus @default(ACTIVE)

  createdBy   String?                    @map("created_by") @db.Uuid
  updatedBy   String?                    @map("updated_by") @db.Uuid
  createdAt   DateTime                   @default(now()) @map("created_at")
  updatedAt   DateTime                   @updatedAt @map("updated_at")
  deletedAt   DateTime?                  @map("deleted_at")

  gateway     PaymentGateway             @relation(fields: [gatewayId], references: [id], onDelete: Restrict)

  @@unique([businessId, gatewayId, mode])
  @@index([businessId])
  @@index([gatewayId])
  @@index([status])
  @@map("payment_gateway_configs")
}

model PaymentMethod {
  id          String              @id @default(uuid()) @db.Uuid
  businessId  String              @map("business_id") @db.Uuid
  gatewayId   String?             @map("gateway_id") @db.Uuid

  name        String              @db.VarChar(150)
  code        String              @db.VarChar(100)
  paymentType PaymentMethodType   @map("payment_type")
  status      PaymentMethodStatus @default(ACTIVE)
  sortOrder   Int                 @default(0) @map("sort_order")

  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  gateway     PaymentGateway?     @relation(fields: [gatewayId], references: [id], onDelete: SetNull)

  @@unique([businessId, code])
  @@index([businessId])
  @@index([gatewayId])
  @@index([paymentType])
  @@index([status])
  @@map("payment_methods")
}

model PaymentWebhookEvent {
  id             String               @id @default(uuid()) @db.Uuid
  businessId      String               @map("business_id") @db.Uuid
  gatewayId       String               @map("gateway_id") @db.Uuid
  orderPaymentId  String?              @map("order_payment_id") @db.Uuid

  eventType       String               @map("event_type") @db.VarChar(100)
  eventId         String?              @map("event_id") @db.VarChar(150)
  payload         Json
  status          PaymentWebhookStatus @default(PENDING)

  processedAt     DateTime?            @map("processed_at")
  createdAt       DateTime             @default(now()) @map("created_at")

  gateway         PaymentGateway       @relation(fields: [gatewayId], references: [id], onDelete: Restrict)

  @@index([businessId])
  @@index([gatewayId])
  @@index([orderPaymentId])
  @@index([eventType])
  @@index([eventId])
  @@index([status])
  @@index([createdAt])
  @@map("payment_webhook_events")
}