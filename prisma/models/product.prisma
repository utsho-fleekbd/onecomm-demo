// =======================
// Enums
// =======================

enum ProductSimpleStatus {
  ACTIVE
  INACTIVE
}

enum CatalogProductStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ProductVariantStatus {
  ACTIVE
  INACTIVE
}

enum ProductAttributeScope {
  PRODUCT
  VARIANT
}

// =======================
// Models
// =======================

model ProductCategory {
  id          String              @id @default(uuid()) @db.Uuid
  businessId  String              @map("business_id") @db.Uuid
  parentId    String?             @map("parent_id") @db.Uuid

  name        String              @db.VarChar(150)
  description String?
  imageUrl    String?             @map("image_url")
  status      ProductSimpleStatus @default(ACTIVE)
  sortOrder   Int                 @default(0) @map("sort_order")

  createdBy   String?             @map("created_by") @db.Uuid
  updatedBy   String?             @map("updated_by") @db.Uuid
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  deletedAt   DateTime?           @map("deleted_at")

  business    Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  parent      ProductCategory?    @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    ProductCategory[]   @relation("CategoryTree")
  products    Product[]

  @@unique([businessId, parentId, name])
  @@index([businessId])
  @@index([parentId])
  @@index([status])
  @@index([deletedAt])
  @@map("product_categories")
}

model ProductBrand {
  id          String              @id @default(uuid()) @db.Uuid
  businessId  String              @map("business_id") @db.Uuid

  name        String              @db.VarChar(150)
  description String?
  logoUrl     String?             @map("logo_url")
  status      ProductSimpleStatus @default(ACTIVE)
  sortOrder   Int                 @default(0) @map("sort_order")

  createdBy   String?             @map("created_by") @db.Uuid
  updatedBy   String?             @map("updated_by") @db.Uuid
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  deletedAt   DateTime?           @map("deleted_at")

  business    Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  products    Product[]

  @@unique([businessId, name])
  @@index([businessId])
  @@index([status])
  @@index([deletedAt])
  @@map("product_brands")
}

model ProductUnit {
  id          String              @id @default(uuid()) @db.Uuid
  businessId  String              @map("business_id") @db.Uuid

  name        String              @db.VarChar(100)
  status      ProductSimpleStatus @default(ACTIVE)

  createdBy   String?             @map("created_by") @db.Uuid
  updatedBy   String?             @map("updated_by") @db.Uuid
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  deletedAt   DateTime?           @map("deleted_at")

  business    Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  products    Product[]

  @@unique([businessId, name])
  @@index([businessId])
  @@index([status])
  @@index([deletedAt])
  @@map("product_units")
}

model ProductTag {
  id          String              @id @default(uuid()) @db.Uuid
  businessId  String              @map("business_id") @db.Uuid

  name        String              @db.VarChar(100)
  status      ProductSimpleStatus @default(ACTIVE)

  createdBy   String?             @map("created_by") @db.Uuid
  updatedBy   String?             @map("updated_by") @db.Uuid
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  deletedAt   DateTime?           @map("deleted_at")

  business    Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  products    ProductTagMap[]

  @@unique([businessId, name])
  @@index([businessId])
  @@index([status])
  @@index([deletedAt])
  @@map("product_tags")
}

model Product {
  id          String               @id @default(uuid()) @db.Uuid
  businessId  String               @map("business_id") @db.Uuid

  categoryId  String?              @map("category_id") @db.Uuid
  brandId     String?              @map("brand_id") @db.Uuid
  unitId      String?              @map("unit_id") @db.Uuid

  name        String               @db.VarChar(200)
  slug        String               @db.VarChar(220)
  description String?
  sku         String?              @db.VarChar(100)
  barcode     String?              @db.VarChar(100)

  hasVariants Boolean              @default(false) @map("has_variants")
  price       Decimal              @default(0) @db.Decimal(12, 2)
  status      CatalogProductStatus @default(DRAFT)

  createdBy   String?              @map("created_by") @db.Uuid
  updatedBy   String?              @map("updated_by") @db.Uuid
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")
  deletedAt   DateTime?            @map("deleted_at")

  business    Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category    ProductCategory?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  brand       ProductBrand?        @relation(fields: [brandId], references: [id], onDelete: SetNull)
  unit        ProductUnit?         @relation(fields: [unitId], references: [id], onDelete: SetNull)

  variants    ProductVariant[]
  attributes  ProductAttribute[]
  images      ProductImage[]
  tags        ProductTagMap[]

  @@unique([businessId, slug])
  @@unique([businessId, sku])
  @@unique([businessId, barcode])
  @@index([businessId])
  @@index([categoryId])
  @@index([brandId])
  @@index([unitId])
  @@index([status])
  @@index([deletedAt])
  @@map("product_products")
}

model ProductVariant {
  id          String               @id @default(uuid()) @db.Uuid
  businessId  String               @map("business_id") @db.Uuid
  productId   String               @map("product_id") @db.Uuid

  sku         String?              @db.VarChar(100)
  barcode     String?              @db.VarChar(100)
  title       String               @db.VarChar(200)
  price       Decimal              @default(0) @db.Decimal(12, 2)
  weight      Decimal?             @db.Decimal(10, 2)
  status      ProductVariantStatus @default(ACTIVE)

  createdBy   String?              @map("created_by") @db.Uuid
  updatedBy   String?              @map("updated_by") @db.Uuid
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")
  deletedAt   DateTime?            @map("deleted_at")

  business    Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  product     Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  images      ProductImage[]
  attributes  ProductVariantAttribute[]

  @@unique([businessId, sku])
  @@unique([businessId, barcode])
  @@index([businessId])
  @@index([productId])
  @@index([status])
  @@index([deletedAt])
  @@map("product_variants")
}

model ProductAttribute {
  id          String                @id @default(uuid()) @db.Uuid
  businessId  String                @map("business_id") @db.Uuid
  productId   String                @map("product_id") @db.Uuid

  name        String                @db.VarChar(100)
  scope       ProductAttributeScope @default(PRODUCT)
  status      ProductSimpleStatus   @default(ACTIVE)

  createdBy   String?               @map("created_by") @db.Uuid
  updatedBy   String?               @map("updated_by") @db.Uuid
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")
  deletedAt   DateTime?             @map("deleted_at")

  business    Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  product     Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  values      ProductAttributeValue[]
  variants    ProductVariantAttribute[]

  @@unique([productId, scope, name])
  @@index([businessId])
  @@index([productId])
  @@index([scope])
  @@index([status])
  @@index([deletedAt])
  @@map("product_attributes")
}

model ProductAttributeValue {
  id          String                    @id @default(uuid()) @db.Uuid
  businessId  String                    @map("business_id") @db.Uuid
  attributeId String                    @map("attribute_id") @db.Uuid

  name        String                    @db.VarChar(100)

  createdBy   String?                   @map("created_by") @db.Uuid
  updatedBy   String?                   @map("updated_by") @db.Uuid
  createdAt   DateTime                  @default(now()) @map("created_at")
  updatedAt   DateTime                  @updatedAt @map("updated_at")
  deletedAt   DateTime?                 @map("deleted_at")

  business    Business                  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  attribute   ProductAttribute          @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  variants    ProductVariantAttribute[]

  @@unique([attributeId, name])
  @@index([businessId])
  @@index([attributeId])
  @@index([deletedAt])
  @@map("product_attribute_values")
}

model ProductVariantAttribute {
  id               String                @id @default(uuid()) @db.Uuid
  variantId         String                @map("variant_id") @db.Uuid
  attributeId       String                @map("attribute_id") @db.Uuid
  attributeValueId  String                @map("attribute_value_id") @db.Uuid

  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")

  variant           ProductVariant        @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attribute         ProductAttribute      @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  attributeValue    ProductAttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)

  @@unique([variantId, attributeId])
  @@index([attributeId])
  @@index([attributeValueId])
  @@map("product_variant_attributes")
}

model ProductImage {
  id          String          @id @default(uuid()) @db.Uuid
  businessId  String          @map("business_id") @db.Uuid
  productId   String          @map("product_id") @db.Uuid
  variantId   String?         @map("variant_id") @db.Uuid

  imageUrl    String          @map("image_url")
  altText     String?         @map("alt_text")
  isThumbnail Boolean         @default(false) @map("is_thumbnail")
  sortOrder   Int             @default(0) @map("sort_order")

  createdBy   String?         @map("created_by") @db.Uuid
  updatedBy   String?         @map("updated_by") @db.Uuid
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  deletedAt   DateTime?       @map("deleted_at")

  business    Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  product     Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([productId])
  @@index([variantId])
  @@index([isThumbnail])
  @@index([deletedAt])
  @@map("product_images")
}

model ProductTagMap {
  id        String     @id @default(uuid()) @db.Uuid
  productId String     @map("product_id") @db.Uuid
  tagId     String     @map("tag_id") @db.Uuid

  createdAt DateTime   @default(now()) @map("created_at")

  product   Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag       ProductTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([productId, tagId])
  @@index([tagId])
  @@map("product_tag_map")
}
