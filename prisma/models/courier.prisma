// ======================================================
// COURIER / SHIPPING MODULE
// ======================================================


// ======================================================
// ENUMS
// ======================================================

enum CourierStatus {
  ACTIVE
  INACTIVE
}

enum CourierConfigMode {
  SANDBOX
  LIVE
}

enum CourierConfigStatus {
  ACTIVE
  INACTIVE
}

enum CourierDeliveryZoneStatus {
  ACTIVE
  INACTIVE
}

enum CourierShippingChargeStatus {
  ACTIVE
  INACTIVE
}

enum CourierShipmentStatus {
  PENDING
  BOOKED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  FAILED
  RETURNED
  CANCELLED
}

enum CourierReceivableStatus {
  PENDING
  PARTIALLY_SETTLED
  SETTLED
  DISPUTED
}

enum CourierSettlementStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}


// ======================================================
// COURIER
// table: courier_couriers
// ======================================================

model Courier {
  id          String        @id @default(uuid()) @db.Uuid

  name        String        @db.VarChar(150)
  description String?
  status      CourierStatus @default(ACTIVE)
  sortOrder   Int           @default(0) @map("sort_order")

  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  configs     CourierConfig[]
  charges     CourierShippingCharge[]
  shipments   CourierShipment[]
  receivables CourierReceivable[]
  settlements CourierSettlement[]

  @@unique([name])
  @@index([status])
  @@map("courier_couriers")
}


// ======================================================
// COURIER CONFIG
// table: courier_configs
// ======================================================

model CourierConfig {
  id         String              @id @default(uuid()) @db.Uuid
  businessId String              @map("business_id") @db.Uuid
  courierId  String              @map("courier_id") @db.Uuid

  configData Json                @map("config_data")
  mode       CourierConfigMode   @default(SANDBOX)
  status     CourierConfigStatus @default(ACTIVE)

  createdBy  String?             @map("created_by") @db.Uuid
  updatedBy  String?             @map("updated_by") @db.Uuid
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")
  deletedAt  DateTime?           @map("deleted_at")

  courier    Courier             @relation(fields: [courierId], references: [id], onDelete: Restrict)

  @@unique([businessId, courierId, mode])
  @@index([businessId])
  @@index([courierId])
  @@index([status])
  @@map("courier_configs")
}


// ======================================================
// DELIVERY ZONE
// table: courier_delivery_zones
// ======================================================

model CourierDeliveryZone {
  id          String                    @id @default(uuid()) @db.Uuid
  businessId  String                    @map("business_id") @db.Uuid

  name        String                    @db.VarChar(150)
  description String?
  status      CourierDeliveryZoneStatus @default(ACTIVE)
  sortOrder   Int                       @default(0) @map("sort_order")

  createdAt   DateTime                  @default(now()) @map("created_at")
  updatedAt   DateTime                  @updatedAt @map("updated_at")
  deletedAt   DateTime?                 @map("deleted_at")

  areas       CourierDeliveryZoneArea[]
  charges     CourierShippingCharge[]
  shipments   CourierShipment[]

  @@unique([businessId, name])
  @@index([businessId])
  @@index([status])
  @@map("courier_delivery_zones")
}


// ======================================================
// DELIVERY ZONE AREA
// table: courier_delivery_zone_areas
// ======================================================

model CourierDeliveryZoneArea {
  id             String   @id @default(uuid()) @db.Uuid
  deliveryZoneId String   @map("delivery_zone_id") @db.Uuid

  areaName       String   @map("area_name") @db.VarChar(150)
  city           String?  @db.VarChar(100)

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  deliveryZone   CourierDeliveryZone @relation(fields: [deliveryZoneId], references: [id], onDelete: Cascade)

  @@index([deliveryZoneId])
  @@index([city])
  @@map("courier_delivery_zone_areas")
}


// ======================================================
// SHIPPING CHARGE
// table: courier_shipping_charges
// ======================================================

model CourierShippingCharge {
  id              String                      @id @default(uuid()) @db.Uuid
  businessId       String                      @map("business_id") @db.Uuid
  deliveryZoneId   String                      @map("delivery_zone_id") @db.Uuid
  courierId        String?                     @map("courier_id") @db.Uuid

  minWeight        Decimal?                    @map("min_weight") @db.Decimal(10, 3)
  maxWeight        Decimal?                    @map("max_weight") @db.Decimal(10, 3)
  shippingCharge   Decimal                     @default(0) @map("shipping_charge") @db.Decimal(12, 2)
  codCharge        Decimal                     @default(0) @map("cod_charge") @db.Decimal(12, 2)
  status           CourierShippingChargeStatus @default(ACTIVE)

  createdAt        DateTime                    @default(now()) @map("created_at")
  updatedAt        DateTime                    @updatedAt @map("updated_at")

  deliveryZone     CourierDeliveryZone         @relation(fields: [deliveryZoneId], references: [id], onDelete: Cascade)
  courier          Courier?                    @relation(fields: [courierId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([deliveryZoneId])
  @@index([courierId])
  @@index([status])
  @@map("courier_shipping_charges")
}


// ======================================================
// SHIPMENT
// table: courier_shipments
// ======================================================

model CourierShipment {
  id                      String                @id @default(uuid()) @db.Uuid
  businessId              String                @map("business_id") @db.Uuid
  orderId                 String                @map("order_id") @db.Uuid
  courierId               String?               @map("courier_id") @db.Uuid
  deliveryZoneId          String?               @map("delivery_zone_id") @db.Uuid

  shipmentNo              String                @map("shipment_no") @db.VarChar(100)
  consignmentId           String?               @map("consignment_id") @db.VarChar(150)
  trackingCode            String?               @map("tracking_code") @db.VarChar(150)
  status                  CourierShipmentStatus @default(PENDING)

  shippingCharge          Decimal               @default(0) @map("shipping_charge") @db.Decimal(12, 2)
  codAmount               Decimal               @default(0) @map("cod_amount") @db.Decimal(12, 2)
  courierFee              Decimal               @default(0) @map("courier_fee") @db.Decimal(12, 2)

  recipientName           String?               @map("recipient_name") @db.VarChar(150)
  recipientPhone          String?               @map("recipient_phone") @db.VarChar(30)
  deliveryAddressSnapshot Json?                 @map("delivery_address_snapshot")

  shippedAt               DateTime?             @map("shipped_at")
  deliveredAt             DateTime?             @map("delivered_at")
  cancelledAt             DateTime?             @map("cancelled_at")

  createdBy               String?               @map("created_by") @db.Uuid
  createdAt               DateTime              @default(now()) @map("created_at")
  updatedAt               DateTime              @updatedAt @map("updated_at")
  deletedAt               DateTime?             @map("deleted_at")

  courier                 Courier?              @relation(fields: [courierId], references: [id], onDelete: SetNull)
  deliveryZone            CourierDeliveryZone?  @relation(fields: [deliveryZoneId], references: [id], onDelete: SetNull)

  items                   CourierShipmentItem[]
  receivable              CourierReceivable?
  settlementItems         CourierSettlementItem[]

  @@unique([businessId, shipmentNo])
  @@unique([consignmentId])
  @@index([businessId])
  @@index([orderId])
  @@index([courierId])
  @@index([deliveryZoneId])
  @@index([status])
  @@index([trackingCode])
  @@map("courier_shipments")
}


// ======================================================
// SHIPMENT ITEM
// table: courier_shipment_items
// ======================================================

model CourierShipmentItem {
  id          String   @id @default(uuid()) @db.Uuid
  shipmentId  String   @map("shipment_id") @db.Uuid
  orderItemId String   @map("order_item_id") @db.Uuid
  productId   String   @map("product_id") @db.Uuid
  variantId   String?  @map("variant_id") @db.Uuid

  quantity    Decimal  @db.Decimal(14, 3)

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  shipment    CourierShipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@index([orderItemId])
  @@index([productId])
  @@index([variantId])
  @@map("courier_shipment_items")
}


// ======================================================
// COURIER RECEIVABLE
// table: courier_receivables
// ======================================================

model CourierReceivable {
  id                     String                  @id @default(uuid()) @db.Uuid
  businessId              String                  @map("business_id") @db.Uuid
  courierId               String                  @map("courier_id") @db.Uuid
  shipmentId              String                  @unique @map("shipment_id") @db.Uuid
  orderId                 String                  @map("order_id") @db.Uuid

  codAmount               Decimal                 @default(0) @map("cod_amount") @db.Decimal(12, 2)
  courierFee              Decimal                 @default(0) @map("courier_fee") @db.Decimal(12, 2)
  netReceivable           Decimal                 @default(0) @map("net_receivable") @db.Decimal(12, 2)

  status                  CourierReceivableStatus @default(PENDING)
  expectedSettlementDate  DateTime?               @map("expected_settlement_date")
  settledAt               DateTime?               @map("settled_at")

  createdAt               DateTime                @default(now()) @map("created_at")
  updatedAt               DateTime                @updatedAt @map("updated_at")

  courier                 Courier                 @relation(fields: [courierId], references: [id], onDelete: Restrict)
  shipment                CourierShipment         @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  settlementItems         CourierSettlementItem[]

  @@index([businessId])
  @@index([courierId])
  @@index([orderId])
  @@index([status])
  @@index([expectedSettlementDate])
  @@map("courier_receivables")
}


// ======================================================
// COURIER SETTLEMENT
// table: courier_settlements
// ======================================================

model CourierSettlement {
  id                    String                  @id @default(uuid()) @db.Uuid
  businessId             String                  @map("business_id") @db.Uuid
  courierId              String                  @map("courier_id") @db.Uuid

  settlementNo           String                  @map("settlement_no") @db.VarChar(100)
  settlementDate         DateTime                @map("settlement_date")

  totalCodAmount         Decimal                 @default(0) @map("total_cod_amount") @db.Decimal(12, 2)
  totalCourierFee        Decimal                 @default(0) @map("total_courier_fee") @db.Decimal(12, 2)
  totalSettlementAmount  Decimal                 @default(0) @map("total_settlement_amount") @db.Decimal(12, 2)

  status                 CourierSettlementStatus @default(DRAFT)
  referenceNo            String?                 @map("reference_no") @db.VarChar(150)
  note                   String?

  createdBy              String?                 @map("created_by") @db.Uuid
  createdAt              DateTime                @default(now()) @map("created_at")
  updatedAt              DateTime                @updatedAt @map("updated_at")
  deletedAt              DateTime?               @map("deleted_at")

  courier                Courier                 @relation(fields: [courierId], references: [id], onDelete: Restrict)
  items                  CourierSettlementItem[]

  @@unique([businessId, settlementNo])
  @@index([businessId])
  @@index([courierId])
  @@index([settlementDate])
  @@index([status])
  @@map("courier_settlements")
}


// ======================================================
// COURIER SETTLEMENT ITEM
// table: courier_settlement_items
// ======================================================

model CourierSettlementItem {
  id                String   @id @default(uuid()) @db.Uuid
  settlementId       String   @map("settlement_id") @db.Uuid
  receivableId       String   @map("receivable_id") @db.Uuid
  shipmentId         String   @map("shipment_id") @db.Uuid

  codAmount          Decimal  @default(0) @map("cod_amount") @db.Decimal(12, 2)
  courierFee         Decimal  @default(0) @map("courier_fee") @db.Decimal(12, 2)
  settlementAmount   Decimal  @default(0) @map("settlement_amount") @db.Decimal(12, 2)

  createdAt          DateTime @default(now()) @map("created_at")

  settlement         CourierSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  receivable         CourierReceivable @relation(fields: [receivableId], references: [id], onDelete: Restrict)
  shipment           CourierShipment   @relation(fields: [shipmentId], references: [id], onDelete: Restrict)

  @@unique([receivableId])
  @@index([settlementId])
  @@index([shipmentId])
  @@map("courier_settlement_items")
}