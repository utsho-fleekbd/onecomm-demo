// ======================================================
// ENUMS
// ======================================================

enum MediaFileType {
  IMAGE
  VIDEO
  DOCUMENT
  AUDIO
  OTHER
}

enum MediaAssetStatus {
  ACTIVE
  INACTIVE
}

enum MediaTagStatus {
  ACTIVE
  INACTIVE
}


// ======================================================
// MEDIA ASSET
// table: media_assets
// ======================================================

model MediaAsset {
  id         String           @id @default(uuid()) @db.Uuid
  businessId String           @map("business_id") @db.Uuid
  uploadedBy String?          @map("uploaded_by") @db.Uuid

  fileName   String           @map("file_name") @db.VarChar(255)
  fileUrl    String           @map("file_url")
  fileType   MediaFileType    @map("file_type")
  mimeType   String?          @map("mime_type") @db.VarChar(100)
  fileSize   Int?             @map("file_size")
  folder     String?          @db.VarChar(150)
  altText    String?          @map("alt_text")
  status     MediaAssetStatus @default(ACTIVE)

  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")
  deletedAt  DateTime?        @map("deleted_at")

  tags       MediaAssetTag[]

  @@index([businessId])
  @@index([uploadedBy])
  @@index([fileType])
  @@index([folder])
  @@index([status])
  @@map("media_assets")
}


// ======================================================
// MEDIA TAG
// table: media_tags
// ======================================================

model MediaTag {
  id         String         @id @default(uuid()) @db.Uuid
  businessId String         @map("business_id") @db.Uuid

  name       String         @db.VarChar(100)
  status     MediaTagStatus @default(ACTIVE)

  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  assets     MediaAssetTag[]

  @@unique([businessId, name])
  @@index([businessId])
  @@index([status])
  @@map("media_tags")
}


// ======================================================
// MEDIA ASSET TAG MAP
// table: media_asset_tags
// ======================================================

model MediaAssetTag {
  id           String     @id @default(uuid()) @db.Uuid
  mediaAssetId String     @map("media_asset_id") @db.Uuid
  tagId        String     @map("tag_id") @db.Uuid

  createdAt    DateTime   @default(now()) @map("created_at")

  mediaAsset   MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)
  tag          MediaTag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([mediaAssetId, tagId])
  @@index([mediaAssetId])
  @@index([tagId])
  @@map("media_asset_tags")
}