// ======================================================
// ENUMS
// ======================================================

enum FinanceAccountType {
  CASH
  BANK
  MOBILE_BANKING
  PAYMENT_GATEWAY
  OTHER
}

enum FinanceAccountStatus {
  ACTIVE
  INACTIVE
}

enum FinanceTransactionType {
  DEBIT
  CREDIT
}

enum FinanceExpenseCategoryStatus {
  ACTIVE
  INACTIVE
}

enum FinanceExpenseStatus {
  DRAFT
  PAID
  CANCELLED
}

enum FinancePartyType {
  CUSTOMER
  SUPPLIER
  COURIER
  PAYMENT_GATEWAY
  EMPLOYEE
  OTHER
}

enum FinanceReceivableStatus {
  PENDING
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum FinancePayableStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  CANCELLED
}

enum FinanceSourceType {
  ORDER
  INVOICE
  SUPPLIER_INVOICE
  SUPPLIER_PAYMENT
  COURIER_RECEIVABLE
  COURIER_SETTLEMENT
  EXPENSE
  REFUND
  MANUAL
}

enum FinanceJournalLineType {
  DEBIT
  CREDIT
}

// ======================================================
// Models
// ======================================================

model FinanceAccount {
  id             String               @id @default(uuid()) @db.Uuid
  businessId     String               @map("business_id") @db.Uuid

  name           String               @db.VarChar(150)
  accountType    FinanceAccountType   @map("account_type")
  accountNumber  String?              @map("account_number") @db.VarChar(100)
  currencyCode   String               @default("BDT") @map("currency_code") @db.VarChar(10)

  openingBalance Decimal              @default(0) @map("opening_balance") @db.Decimal(12, 2)
  currentBalance Decimal              @default(0) @map("current_balance") @db.Decimal(12, 2)

  status         FinanceAccountStatus @default(ACTIVE)

  createdBy      String?              @map("created_by") @db.Uuid
  updatedBy      String?              @map("updated_by") @db.Uuid
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  deletedAt      DateTime?            @map("deleted_at")

  transactions   FinanceAccountTransaction[]
  expenses       FinanceExpense[]
  journalLines   FinanceJournalEntryLine[]

  @@unique([businessId, name])
  @@index([businessId])
  @@index([accountType])
  @@index([status])
  @@map("finance_accounts")
}

model FinanceAccountTransaction {
  id              String                 @id @default(uuid()) @db.Uuid
  businessId       String                 @map("business_id") @db.Uuid
  accountId        String                 @map("account_id") @db.Uuid

  transactionNo    String                 @map("transaction_no") @db.VarChar(100)
  transactionType  FinanceTransactionType @map("transaction_type")

  amount           Decimal                @db.Decimal(12, 2)
  balanceBefore    Decimal                @map("balance_before") @db.Decimal(12, 2)
  balanceAfter     Decimal                @map("balance_after") @db.Decimal(12, 2)

  referenceType    FinanceSourceType?     @map("reference_type")
  referenceId      String?                @map("reference_id") @db.Uuid

  note             String?
  createdBy        String?                @map("created_by") @db.Uuid
  createdAt        DateTime               @default(now()) @map("created_at")

  account          FinanceAccount         @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@unique([businessId, transactionNo])
  @@index([businessId])
  @@index([accountId])
  @@index([transactionType])
  @@index([referenceType, referenceId])
  @@index([createdAt])
  @@map("finance_account_transactions")
}

model FinanceExpenseCategory {
  id          String                       @id @default(uuid()) @db.Uuid
  businessId  String                       @map("business_id") @db.Uuid

  name        String                       @db.VarChar(150)
  description String?
  status      FinanceExpenseCategoryStatus @default(ACTIVE)

  createdAt   DateTime                     @default(now()) @map("created_at")
  updatedAt   DateTime                     @updatedAt @map("updated_at")
  deletedAt   DateTime?                    @map("deleted_at")

  expenses    FinanceExpense[]

  @@unique([businessId, name])
  @@index([businessId])
  @@index([status])
  @@map("finance_expense_categories")
}

model FinanceExpense {
  id                String               @id @default(uuid()) @db.Uuid
  businessId         String               @map("business_id") @db.Uuid
  accountId          String               @map("account_id") @db.Uuid
  expenseCategoryId  String               @map("expense_category_id") @db.Uuid

  expenseNo          String               @map("expense_no") @db.VarChar(100)
  title              String               @db.VarChar(200)
  amount             Decimal              @db.Decimal(12, 2)
  expenseDate        DateTime             @map("expense_date")
  status             FinanceExpenseStatus @default(DRAFT)

  referenceNo        String?              @map("reference_no") @db.VarChar(150)
  note               String?

  createdBy          String?              @map("created_by") @db.Uuid
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")
  deletedAt          DateTime?            @map("deleted_at")

  account            FinanceAccount       @relation(fields: [accountId], references: [id], onDelete: Restrict)
  category           FinanceExpenseCategory @relation(fields: [expenseCategoryId], references: [id], onDelete: Restrict)

  @@unique([businessId, expenseNo])
  @@index([businessId])
  @@index([accountId])
  @@index([expenseCategoryId])
  @@index([status])
  @@index([expenseDate])
  @@map("finance_expenses")
}

model FinanceReceivable {
  id             String                  @id @default(uuid()) @db.Uuid
  businessId      String                  @map("business_id") @db.Uuid

  receivableNo    String                  @map("receivable_no") @db.VarChar(100)
  partyType       FinancePartyType        @map("party_type")
  partyId         String?                 @map("party_id") @db.Uuid

  sourceType      FinanceSourceType       @map("source_type")
  sourceId        String?                 @map("source_id") @db.Uuid

  totalAmount     Decimal                 @default(0) @map("total_amount") @db.Decimal(12, 2)
  receivedAmount  Decimal                 @default(0) @map("received_amount") @db.Decimal(12, 2)

  status          FinanceReceivableStatus @default(PENDING)
  dueDate         DateTime?               @map("due_date")
  note            String?

  createdAt       DateTime                @default(now()) @map("created_at")
  updatedAt       DateTime                @updatedAt @map("updated_at")

  @@unique([businessId, receivableNo])
  @@index([businessId])
  @@index([partyType, partyId])
  @@index([sourceType, sourceId])
  @@index([status])
  @@index([dueDate])
  @@map("finance_receivables")
}

model FinancePayable {
  id          String               @id @default(uuid()) @db.Uuid
  businessId  String               @map("business_id") @db.Uuid

  payableNo   String               @map("payable_no") @db.VarChar(100)
  partyType   FinancePartyType     @map("party_type")
  partyId     String?              @map("party_id") @db.Uuid

  sourceType  FinanceSourceType    @map("source_type")
  sourceId    String?              @map("source_id") @db.Uuid

  totalAmount Decimal              @default(0) @map("total_amount") @db.Decimal(12, 2)
  paidAmount  Decimal              @default(0) @map("paid_amount") @db.Decimal(12, 2)

  status      FinancePayableStatus @default(PENDING)
  dueDate     DateTime?            @map("due_date")
  note        String?

  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")

  @@unique([businessId, payableNo])
  @@index([businessId])
  @@index([partyType, partyId])
  @@index([sourceType, sourceId])
  @@index([status])
  @@index([dueDate])
  @@map("finance_payables")
}

model FinanceJournalEntry {
  id            String             @id @default(uuid()) @db.Uuid
  businessId     String             @map("business_id") @db.Uuid

  journalNo      String             @map("journal_no") @db.VarChar(100)
  journalDate    DateTime           @map("journal_date")

  referenceType  FinanceSourceType? @map("reference_type")
  referenceId    String?            @map("reference_id") @db.Uuid

  note           String?
  createdBy      String?            @map("created_by") @db.Uuid
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  lines          FinanceJournalEntryLine[]

  @@unique([businessId, journalNo])
  @@index([businessId])
  @@index([journalDate])
  @@index([referenceType, referenceId])
  @@map("finance_journal_entries")
}

model FinanceJournalEntryLine {
  id             String                 @id @default(uuid()) @db.Uuid
  journalEntryId String                 @map("journal_entry_id") @db.Uuid
  accountId      String                 @map("account_id") @db.Uuid

  entryType      FinanceJournalLineType @map("entry_type")
  amount         Decimal                @db.Decimal(12, 2)
  note           String?

  createdAt      DateTime               @default(now()) @map("created_at")

  journalEntry   FinanceJournalEntry    @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account        FinanceAccount         @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([journalEntryId])
  @@index([accountId])
  @@index([entryType])
  @@map("finance_journal_entry_lines")
}