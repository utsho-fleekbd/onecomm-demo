// ======================================================
// ENUMS
// ======================================================

enum WebsiteTemplateStatus {
  ACTIVE
  INACTIVE
}

enum WebsiteStatus {
  DRAFT
  PUBLISHED
  UNPUBLISHED
  ARCHIVED
}

enum WebsiteDomainType {
  SUBDOMAIN
  CUSTOM_DOMAIN
}

enum WebsiteDomainVerificationStatus {
  PENDING
  VERIFIED
  FAILED
}

enum WebsiteDomainSslStatus {
  PENDING
  ACTIVE
  FAILED
}

enum WebsitePageStatus {
  DRAFT
  PUBLISHED
  UNPUBLISHED
  ARCHIVED
}

enum WebsitePageType {
  HOME
  PRODUCT_LIST
  PRODUCT_DETAILS
  CATEGORY
  CART
  CHECKOUT
  ABOUT
  CONTACT
  CUSTOM
}

enum WebsiteSectionStatus {
  ACTIVE
  INACTIVE
}

enum WebsiteComponentStatus {
  ACTIVE
  INACTIVE
}

// ======================================================
// Models
// ======================================================

model WebsiteTemplate {
  id String @id @default(uuid()) @db.Uuid

  name         String  @db.VarChar(150)
  slug         String  @db.VarChar(180)
  category     String? @db.VarChar(100)
  thumbnailUrl String? @map("thumbnail_url")
  previewUrl   String? @map("preview_url")
  configSchema Json?   @map("config_schema")

  status    WebsiteTemplateStatus @default(ACTIVE)
  sortOrder Int                   @default(0) @map("sort_order")

  createdBy String?   @map("created_by") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  websites Website[]

  @@unique([slug])
  @@index([category])
  @@index([status])
  @@map("website_templates")
}

model Website {
  id               String  @id @default(uuid()) @db.Uuid
  businessId       String  @map("business_id") @db.Uuid
  templateId       String? @map("template_id") @db.Uuid
  currentVersionId String? @unique @map("current_version_id") @db.Uuid

  name   String        @db.VarChar(150)
  slug   String        @db.VarChar(180)
  status WebsiteStatus @default(DRAFT)

  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  template       WebsiteTemplate?       @relation(fields: [templateId], references: [id], onDelete: SetNull)
  currentVersion WebsitePublishVersion? @relation("CurrentWebsiteVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)

  config          WebsiteConfig?
  domains         WebsiteDomain[]
  pages           WebsitePage[]
  themeSetting    WebsiteThemeSetting?
  seoSettings     WebsiteSeoSetting[]
  publishVersions WebsitePublishVersion[] @relation("WebsitePublishVersions")

  @@unique([businessId, slug])
  @@index([businessId])
  @@index([templateId])
  @@index([status])
  @@map("website_websites")
}

model WebsiteConfig {
  id        String @id @default(uuid()) @db.Uuid
  websiteId String @unique @map("website_id") @db.Uuid

  headerConfig     Json? @map("header_config")
  footerConfig     Json? @map("footer_config")
  navigationConfig Json? @map("navigation_config")
  generalConfig    Json? @map("general_config")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  website Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@map("website_configs")
}

model WebsiteDomain {
  id        String @id @default(uuid()) @db.Uuid
  websiteId String @map("website_id") @db.Uuid

  domain             String?                         @db.VarChar(255)
  subdomain          String?                         @db.VarChar(255)
  domainType         WebsiteDomainType               @map("domain_type")
  isPrimary          Boolean                         @default(false) @map("is_primary")
  verificationStatus WebsiteDomainVerificationStatus @default(PENDING) @map("verification_status")
  sslStatus          WebsiteDomainSslStatus          @default(PENDING) @map("ssl_status")
  verifiedAt         DateTime?                       @map("verified_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  website Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@index([websiteId])
  @@index([domain])
  @@index([subdomain])
  @@index([domainType])
  @@index([isPrimary])
  @@index([verificationStatus])
  @@map("website_domains")
}

model WebsitePage {
  id        String @id @default(uuid()) @db.Uuid
  websiteId String @map("website_id") @db.Uuid

  title      String            @db.VarChar(180)
  slug       String            @db.VarChar(180)
  pageType   WebsitePageType   @default(CUSTOM) @map("page_type")
  status     WebsitePageStatus @default(DRAFT)
  sortOrder  Int               @default(0) @map("sort_order")
  isHomepage Boolean           @default(false) @map("is_homepage")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  website    Website              @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  sections   WebsitePageSection[]
  seoSetting WebsiteSeoSetting?

  @@unique([websiteId, slug])
  @@index([websiteId])
  @@index([pageType])
  @@index([status])
  @@index([isHomepage])
  @@map("website_pages")
}

model WebsitePageSection {
  id          String  @id @default(uuid()) @db.Uuid
  pageId      String  @map("page_id") @db.Uuid
  componentId String? @map("component_id") @db.Uuid

  name          String?              @db.VarChar(150)
  sectionKey    String               @map("section_key") @db.VarChar(120)
  contentConfig Json?                @map("content_config")
  styleConfig   Json?                @map("style_config")
  sortOrder     Int                  @default(0) @map("sort_order")
  status        WebsiteSectionStatus @default(ACTIVE)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  page      WebsitePage       @relation(fields: [pageId], references: [id], onDelete: Cascade)
  component WebsiteComponent? @relation(fields: [componentId], references: [id], onDelete: SetNull)

  @@index([pageId])
  @@index([componentId])
  @@index([sectionKey])
  @@index([status])
  @@map("website_page_sections")
}

model WebsiteComponent {
  id String @id @default(uuid()) @db.Uuid

  name            String                 @db.VarChar(150)
  code            String                 @db.VarChar(120)
  componentType   String                 @map("component_type") @db.VarChar(100)
  previewImageUrl String?                @map("preview_image_url")
  defaultConfig   Json?                  @map("default_config")
  status          WebsiteComponentStatus @default(ACTIVE)
  sortOrder       Int                    @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sections WebsitePageSection[]

  @@unique([code])
  @@index([componentType])
  @@index([status])
  @@map("website_components")
}

model WebsiteThemeSetting {
  id        String @id @default(uuid()) @db.Uuid
  websiteId String @unique @map("website_id") @db.Uuid

  primaryColor   String? @map("primary_color") @db.VarChar(30)
  secondaryColor String? @map("secondary_color") @db.VarChar(30)
  accentColor    String? @map("accent_color") @db.VarChar(30)
  fontFamily     String? @map("font_family") @db.VarChar(100)
  logoUrl        String? @map("logo_url")
  faviconUrl     String? @map("favicon_url")
  customCss      String? @map("custom_css")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  website Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@map("website_theme_settings")
}

model WebsiteSeoSetting {
  id        String  @id @default(uuid()) @db.Uuid
  websiteId String  @map("website_id") @db.Uuid
  pageId    String? @unique @map("page_id") @db.Uuid

  metaTitle       String? @map("meta_title") @db.VarChar(255)
  metaDescription String? @map("meta_description")
  metaKeywords    String? @map("meta_keywords")
  ogTitle         String? @map("og_title") @db.VarChar(255)
  ogDescription   String? @map("og_description")
  ogImageUrl      String? @map("og_image_url")
  canonicalUrl    String? @map("canonical_url")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  website Website      @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  page    WebsitePage? @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([websiteId])
  @@map("website_seo_settings")
}

model WebsitePublishVersion {
  id        String @id @default(uuid()) @db.Uuid
  websiteId String @map("website_id") @db.Uuid

  versionNo    Int  @map("version_no")
  snapshotData Json @map("snapshot_data")

  publishedBy String?  @map("published_by") @db.Uuid
  publishedAt DateTime @map("published_at")
  createdAt   DateTime @default(now()) @map("created_at")

  website        Website  @relation("WebsitePublishVersions", fields: [websiteId], references: [id], onDelete: Cascade)
  currentWebsite Website? @relation("CurrentWebsiteVersion")

  @@unique([websiteId, versionNo])
  @@index([websiteId])
  @@index([publishedAt])
  @@map("website_publish_versions")
}
