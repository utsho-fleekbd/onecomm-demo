model Business {
    id           Int            @id @default(autoincrement())
    ownerUserId  Int            @map("owner_user_id")
    name         String         @db.VarChar(150)
    slug         String         @db.VarChar(180)
    email        String?        @db.VarChar(255)
    phone        String?        @db.VarChar(30)
    country      String?        @db.VarChar(100)
    currencyCode String         @default("BDT") @map("currency_code") @db.VarChar(10)
    timezone     String         @default("Asia/Dhaka") @db.VarChar(100)
    status       BusinessStatus @default(TRIAL)

    createdById Int? @map("created_by")
    updatedById Int? @map("updated_by")

    createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
    updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
    deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

    ownerUser SystemUser  @relation("BusinessOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
    createdBy SystemUser? @relation("BusinessCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
    updatedBy SystemUser? @relation("BusinessUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

    settings  BusinessSetting?
    branding  BusinessBranding?
    members   BusinessMember[]
    roles     RbacRole[]
    auditLogs SystemAuditLog[]

    @@unique([slug, ownerUserId])
    @@index([ownerUserId])
    @@index([status])
    @@index([deletedAt])
    @@map("business_businesses")
}

model BusinessSetting {
    id                   Int     @id @default(autoincrement())
    businessId           Int     @unique @map("business_id")
    orderPrefix          String  @default("ORD") @map("order_prefix") @db.VarChar(20)
    invoicePrefix        String  @default("INV") @map("invoice_prefix") @db.VarChar(20)
    defaultLanguage      String  @default("en") @map("default_language") @db.VarChar(10)
    defaultCurrency      String  @default("BDT") @map("default_currency") @db.VarChar(10)
    timezone             String  @default("Asia/Dhaka") @db.VarChar(100)
    lowStockThreshold    Int     @default(5) @map("low_stock_threshold")
    allowBackorder       Boolean @default(false) @map("allow_backorder")
    autoConfirmOrder     Boolean @default(false) @map("auto_confirm_order")
    codEnabled           Boolean @default(true) @map("cod_enabled")
    onlinePaymentEnabled Boolean @default(false) @map("online_payment_enabled")

    createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
    updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

    business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

    @@map("business_settings")
}

model BusinessBranding {
    id             Int     @id @default(autoincrement())
    businessId     Int     @unique @map("business_id")
    logoUrl        String? @map("logo_url") @db.Text
    faviconUrl     String? @map("favicon_url") @db.Text
    primaryColor   String? @map("primary_color") @db.VarChar(20)
    secondaryColor String? @map("secondary_color") @db.VarChar(20)
    accentColor    String? @map("accent_color") @db.VarChar(20)
    fontFamily     String? @map("font_family") @db.VarChar(100)
    seoTitle       String? @map("seo_title") @db.VarChar(255)
    seoDescription String? @map("seo_description") @db.Text

    createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
    updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

    business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

    @@map("business_branding")
}

model BusinessMember {
    id         Int                  @id @default(autoincrement())
    businessId Int                  @map("business_id")
    userId     Int                  @map("user_id")
    status     BusinessMemberStatus @default(ACTIVE)
    joinedAt   DateTime?            @map("joined_at") @db.Timestamptz(6)

    createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
    updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
    deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

    business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
    user     SystemUser       @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([businessId, userId])
    @@index([businessId])
    @@index([userId])
    @@index([status])
    @@index([deletedAt])
    @@map("business_members")
}
