// ======================================================
// ENUMS
// ======================================================

enum OrderCustomerStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum OrderAddressType {
  HOME
  OFFICE
  SHIPPING
  BILLING
  OTHER
}

enum OrderCartStatus {
  ACTIVE
  ORDERED
  ABANDONED
  EXPIRED
}

enum OrderType {
  ONLINE
  POS
  ADMIN
}

enum OrderSource {
  WEBSITE
  POS
  ADMIN_PANEL
  MOBILE_APP
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum OrderPaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum OrderDiscountType {
  FIXED
  PERCENTAGE
}

enum OrderDiscountSource {
  MANUAL
  COUPON
  PROMOTION
}

enum OrderPaymentMethod {
  CASH
  COD
  BKASH
  NAGAD
  CARD
  BANK_TRANSFER
  OTHER
}

enum OrderReturnStatus {
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED
}

enum OrderRefundMethod {
  CASH
  BKASH
  NAGAD
  CARD
  BANK_TRANSFER
  OTHER
}

enum OrderRefundStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}


// ======================================================
// Models
// ======================================================

model OrderCustomer {
  id         String              @id @default(uuid()) @db.Uuid
  businessId String              @map("business_id") @db.Uuid

  name       String              @db.VarChar(150)
  email      String?             @db.VarChar(150)
  phone      String?             @db.VarChar(30)
  status     OrderCustomerStatus @default(ACTIVE)
  note       String?

  createdBy  String?             @map("created_by") @db.Uuid
  updatedBy  String?             @map("updated_by") @db.Uuid
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")
  deletedAt  DateTime?           @map("deleted_at")

  addresses  OrderCustomerAddress[]
  carts      OrderCart[]
  orders     OrderOrder[]

  @@index([businessId])
  @@index([phone])
  @@index([email])
  @@index([status])
  @@map("order_customers")
}

model OrderCustomerAddress {
  id          String           @id @default(uuid()) @db.Uuid
  customerId  String           @map("customer_id") @db.Uuid

  addressType OrderAddressType @default(HOME) @map("address_type")
  name        String?          @db.VarChar(150)
  address     String
  city        String?          @db.VarChar(100)
  country     String?          @db.VarChar(100)
  isDefault   Boolean          @default(false) @map("is_default")

  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  deletedAt   DateTime?        @map("deleted_at")

  customer    OrderCustomer    @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([addressType])
  @@index([isDefault])
  @@map("order_customer_addresses")
}

model OrderCart {
  id         String          @id @default(uuid()) @db.Uuid
  businessId String          @map("business_id") @db.Uuid
  customerId String?         @map("customer_id") @db.Uuid

  sessionId  String?         @map("session_id") @db.VarChar(150)
  status     OrderCartStatus @default(ACTIVE)

  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")
  expiresAt  DateTime?       @map("expires_at")

  customer   OrderCustomer?  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items      OrderCartItem[]

  @@index([businessId])
  @@index([customerId])
  @@index([sessionId])
  @@index([status])
  @@map("order_carts")
}

model OrderCartItem {
  id        String   @id @default(uuid()) @db.Uuid
  cartId    String   @map("cart_id") @db.Uuid
  productId String   @map("product_id") @db.Uuid
  variantId String?  @map("variant_id") @db.Uuid

  quantity  Decimal  @db.Decimal(14, 3)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  cart      OrderCart @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@index([cartId])
  @@index([productId])
  @@index([variantId])
  @@map("order_cart_items")
}

model OrderOrder {
  id                      String             @id @default(uuid()) @db.Uuid
  businessId              String             @map("business_id") @db.Uuid
  customerId              String?            @map("customer_id") @db.Uuid
  locationId              String?            @map("location_id") @db.Uuid

  orderNo                 String             @map("order_no") @db.VarChar(100)
  orderType               OrderType          @map("order_type")
  orderSource             OrderSource        @map("order_source")
  status                  OrderStatus        @default(PENDING)
  paymentStatus           OrderPaymentStatus @default(UNPAID) @map("payment_status")

  customerName            String?            @map("customer_name") @db.VarChar(150)
  customerPhone           String?            @map("customer_phone") @db.VarChar(30)
  customerEmail           String?            @map("customer_email") @db.VarChar(150)
  shippingAddressSnapshot Json?              @map("shipping_address_snapshot")

  subtotal                Decimal            @default(0) @db.Decimal(12, 2)
  discountTotal           Decimal            @default(0) @map("discount_total") @db.Decimal(12, 2)
  taxTotal                Decimal            @default(0) @map("tax_total") @db.Decimal(12, 2)
  shippingCharge          Decimal            @default(0) @map("shipping_charge") @db.Decimal(12, 2)
  totalAmount             Decimal            @default(0) @map("total_amount") @db.Decimal(12, 2)
  paidAmount              Decimal            @default(0) @map("paid_amount") @db.Decimal(12, 2)

  note                    String?
  createdBy               String?            @map("created_by") @db.Uuid
  createdAt               DateTime           @default(now()) @map("created_at")
  updatedAt               DateTime           @updatedAt @map("updated_at")
  deletedAt               DateTime?          @map("deleted_at")

  customer                OrderCustomer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)

  items                   OrderOrderItem[]
  statusLogs              OrderStatusLog[]
  discounts               OrderDiscount[]
  payments                OrderPayment[]
  returns                 OrderReturn[]
  refunds                 OrderRefund[]

  @@unique([businessId, orderNo])
  @@index([businessId])
  @@index([customerId])
  @@index([locationId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  @@map("order_orders")
}

model OrderOrderItem {
  id             String   @id @default(uuid()) @db.Uuid
  orderId        String   @map("order_id") @db.Uuid
  productId      String   @map("product_id") @db.Uuid
  variantId      String?  @map("variant_id") @db.Uuid

  quantity       Decimal  @db.Decimal(14, 3)
  unitPrice      Decimal  @map("unit_price") @db.Decimal(12, 2)
  discountAmount Decimal  @default(0) @map("discount_amount") @db.Decimal(12, 2)
  taxAmount      Decimal  @default(0) @map("tax_amount") @db.Decimal(12, 2)
  lineTotal      Decimal  @map("line_total") @db.Decimal(12, 2)

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  order          OrderOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  returnItems    OrderReturnItem[]

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
  @@map("order_order_items")
}

model OrderStatusLog {
  id         String       @id @default(uuid()) @db.Uuid
  orderId    String       @map("order_id") @db.Uuid

  fromStatus OrderStatus? @map("from_status")
  toStatus   OrderStatus  @map("to_status")
  note       String?
  changedBy  String?      @map("changed_by") @db.Uuid

  createdAt  DateTime     @default(now()) @map("created_at")

  order      OrderOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([toStatus])
  @@index([createdAt])
  @@map("order_status_logs")
}

model OrderDiscount {
  id             String              @id @default(uuid()) @db.Uuid
  orderId         String              @map("order_id") @db.Uuid

  discountType    OrderDiscountType   @map("discount_type")
  discountSource  OrderDiscountSource @map("discount_source")
  code            String?             @db.VarChar(100)
  amount          Decimal             @db.Decimal(12, 2)
  note            String?

  createdAt       DateTime            @default(now()) @map("created_at")

  order           OrderOrder          @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([code])
  @@map("order_discounts")
}

model OrderPayment {
  id                   String             @id @default(uuid()) @db.Uuid
  businessId            String             @map("business_id") @db.Uuid
  orderId               String             @map("order_id") @db.Uuid

  paymentNo             String             @map("payment_no") @db.VarChar(100)
  amount                Decimal            @db.Decimal(12, 2)
  paymentMethod         OrderPaymentMethod @map("payment_method")
  paymentStatus         OrderPaymentStatus @default(UNPAID) @map("payment_status")
  transactionReference  String?            @map("transaction_reference") @db.VarChar(150)

  paidAt                DateTime?          @map("paid_at")
  createdBy             String?            @map("created_by") @db.Uuid
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")

  order                 OrderOrder         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  refunds               OrderRefund[]

  @@unique([businessId, paymentNo])
  @@index([businessId])
  @@index([orderId])
  @@index([paymentMethod])
  @@index([paymentStatus])
  @@index([paidAt])
  @@map("order_payments")
}

model OrderReturn {
  id          String            @id @default(uuid()) @db.Uuid
  businessId  String            @map("business_id") @db.Uuid
  orderId     String            @map("order_id") @db.Uuid

  returnNo    String            @map("return_no") @db.VarChar(100)
  status      OrderReturnStatus @default(REQUESTED)
  reason      String?
  totalAmount Decimal           @default(0) @map("total_amount") @db.Decimal(12, 2)

  createdBy   String?           @map("created_by") @db.Uuid
  approvedBy  String?           @map("approved_by") @db.Uuid
  approvedAt  DateTime?         @map("approved_at")

  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  deletedAt   DateTime?         @map("deleted_at")

  order       OrderOrder        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items       OrderReturnItem[]
  refunds     OrderRefund[]

  @@unique([businessId, returnNo])
  @@index([businessId])
  @@index([orderId])
  @@index([status])
  @@map("order_returns")
}

model OrderReturnItem {
  id          String   @id @default(uuid()) @db.Uuid
  returnId    String   @map("return_id") @db.Uuid
  orderItemId String   @map("order_item_id") @db.Uuid
  productId   String   @map("product_id") @db.Uuid
  variantId   String?  @map("variant_id") @db.Uuid

  quantity    Decimal  @db.Decimal(14, 3)
  unitPrice   Decimal  @map("unit_price") @db.Decimal(12, 2)
  lineTotal   Decimal  @map("line_total") @db.Decimal(12, 2)
  reason      String?

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  return      OrderReturn    @relation(fields: [returnId], references: [id], onDelete: Cascade)
  orderItem   OrderOrderItem @relation(fields: [orderItemId], references: [id], onDelete: Restrict)

  @@index([returnId])
  @@index([orderItemId])
  @@index([productId])
  @@index([variantId])
  @@map("order_return_items")
}

model OrderRefund {
  id                   String            @id @default(uuid()) @db.Uuid
  businessId            String            @map("business_id") @db.Uuid
  orderId               String            @map("order_id") @db.Uuid
  returnId              String?           @map("return_id") @db.Uuid
  paymentId             String?           @map("payment_id") @db.Uuid

  refundNo              String            @map("refund_no") @db.VarChar(100)
  amount                Decimal           @db.Decimal(12, 2)
  refundMethod          OrderRefundMethod @map("refund_method")
  refundStatus          OrderRefundStatus @default(PENDING) @map("refund_status")
  transactionReference  String?           @map("transaction_reference") @db.VarChar(150)

  processedBy           String?           @map("processed_by") @db.Uuid
  processedAt           DateTime?         @map("processed_at")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")

  order                 OrderOrder        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  return                OrderReturn?      @relation(fields: [returnId], references: [id], onDelete: SetNull)
  payment               OrderPayment?     @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@unique([businessId, refundNo])
  @@index([businessId])
  @@index([orderId])
  @@index([returnId])
  @@index([paymentId])
  @@index([refundStatus])
  @@map("order_refunds")
}