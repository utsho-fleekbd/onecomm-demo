// ======================================================
// ENUMS
// ======================================================

enum SupplierStatus {
  ACTIVE
  INACTIVE
}

enum SupplierProductMapStatus {
  ACTIVE
  INACTIVE
}

enum SupplierPurchaseOrderStatus {
  DRAFT
  ORDERED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum SupplierInvoiceStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  CANCELLED
}

enum SupplierPaymentMethod {
  CASH
  BANK_TRANSFER
  BKASH
  NAGAD
  CHEQUE
  OTHER
}

enum SupplierPurchaseReturnStatus {
  DRAFT
  PENDING
  COMPLETED
  CANCELLED
}

// ======================================================
// Models
// ======================================================

model Supplier {
  id          String         @id @default(uuid()) @db.Uuid
  businessId  String         @map("business_id") @db.Uuid

  name        String         @db.VarChar(150)
  companyName String?        @map("company_name") @db.VarChar(150)
  email       String?        @db.VarChar(150)
  phone       String?        @db.VarChar(30)
  address     String?
  city        String?        @db.VarChar(100)
  country     String?        @db.VarChar(100)
  status      SupplierStatus @default(ACTIVE)
  note        String?

  createdBy   String?        @map("created_by") @db.Uuid
  updatedBy   String?        @map("updated_by") @db.Uuid
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  deletedAt   DateTime?      @map("deleted_at")

  products    SupplierProductMap[]
  orders      SupplierPurchaseOrder[]
  invoices    SupplierInvoice[]
  payments    SupplierPayment[]
  returns     SupplierPurchaseReturn[]

  @@index([businessId])
  @@index([status])
  @@index([phone])
  @@index([email])
  @@map("supplier_suppliers")
}

model SupplierProductMap {
  id                String                   @id @default(uuid()) @db.Uuid
  businessId         String                   @map("business_id") @db.Uuid
  supplierId         String                   @map("supplier_id") @db.Uuid
  productId          String                   @map("product_id") @db.Uuid
  variantId          String?                  @map("variant_id") @db.Uuid

  supplierSku        String?                  @map("supplier_sku") @db.VarChar(100)
  lastPurchasePrice  Decimal?                 @map("last_purchase_price") @db.Decimal(12, 2)
  minOrderQuantity   Decimal?                 @map("min_order_quantity") @db.Decimal(14, 3)
  leadTimeDays       Int?                     @map("lead_time_days")
  status             SupplierProductMapStatus @default(ACTIVE)

  createdAt          DateTime                 @default(now()) @map("created_at")
  updatedAt          DateTime                 @updatedAt @map("updated_at")

  supplier           Supplier                 @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([supplierId])
  @@index([productId])
  @@index([variantId])
  @@index([status])
  @@map("supplier_product_map")
}

model SupplierPurchaseOrder {
  id                   String                      @id @default(uuid()) @db.Uuid
  businessId            String                      @map("business_id") @db.Uuid
  supplierId            String                      @map("supplier_id") @db.Uuid
  locationId            String                      @map("location_id") @db.Uuid

  purchaseOrderNo       String                      @map("purchase_order_no") @db.VarChar(100)
  orderDate             DateTime                    @map("order_date")
  expectedDeliveryDate  DateTime?                   @map("expected_delivery_date")
  status                SupplierPurchaseOrderStatus @default(DRAFT)

  subtotal              Decimal                     @default(0) @db.Decimal(12, 2)
  discountTotal         Decimal                     @default(0) @map("discount_total") @db.Decimal(12, 2)
  taxTotal              Decimal                     @default(0) @map("tax_total") @db.Decimal(12, 2)
  shippingCost          Decimal                     @default(0) @map("shipping_cost") @db.Decimal(12, 2)
  totalAmount           Decimal                     @default(0) @map("total_amount") @db.Decimal(12, 2)

  note                  String?
  createdBy             String?                     @map("created_by") @db.Uuid
  approvedBy            String?                     @map("approved_by") @db.Uuid
  approvedAt            DateTime?                   @map("approved_at")

  createdAt             DateTime                    @default(now()) @map("created_at")
  updatedAt             DateTime                    @updatedAt @map("updated_at")
  deletedAt             DateTime?                   @map("deleted_at")

  supplier              Supplier                    @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  items                 SupplierPurchaseOrderItem[]
  invoices              SupplierInvoice[]
  returns               SupplierPurchaseReturn[]

  @@unique([businessId, purchaseOrderNo])
  @@index([businessId])
  @@index([supplierId])
  @@index([locationId])
  @@index([status])
  @@index([orderDate])
  @@map("supplier_purchase_orders")
}

model SupplierPurchaseOrderItem {
  id                String   @id @default(uuid()) @db.Uuid
  purchaseOrderId   String   @map("purchase_order_id") @db.Uuid
  productId         String   @map("product_id") @db.Uuid
  variantId         String?  @map("variant_id") @db.Uuid

  quantityOrdered   Decimal  @map("quantity_ordered") @db.Decimal(14, 3)
  quantityReceived  Decimal  @default(0) @map("quantity_received") @db.Decimal(14, 3)
  unitCost          Decimal  @map("unit_cost") @db.Decimal(12, 2)
  discountAmount    Decimal  @default(0) @map("discount_amount") @db.Decimal(12, 2)
  taxAmount         Decimal  @default(0) @map("tax_amount") @db.Decimal(12, 2)
  lineTotal         Decimal  @map("line_total") @db.Decimal(12, 2)

  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  purchaseOrder     SupplierPurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@index([productId])
  @@index([variantId])
  @@map("supplier_purchase_order_items")
}

model SupplierInvoice {
  id              String                @id @default(uuid()) @db.Uuid
  businessId       String                @map("business_id") @db.Uuid
  supplierId       String                @map("supplier_id") @db.Uuid
  purchaseOrderId  String?               @map("purchase_order_id") @db.Uuid

  invoiceNo        String                @map("invoice_no") @db.VarChar(100)
  invoiceDate      DateTime              @map("invoice_date")
  dueDate          DateTime?             @map("due_date")
  status           SupplierInvoiceStatus @default(UNPAID)

  subtotal         Decimal               @default(0) @db.Decimal(12, 2)
  discountTotal    Decimal               @default(0) @map("discount_total") @db.Decimal(12, 2)
  taxTotal         Decimal               @default(0) @map("tax_total") @db.Decimal(12, 2)
  shippingCost     Decimal               @default(0) @map("shipping_cost") @db.Decimal(12, 2)
  totalAmount      Decimal               @default(0) @map("total_amount") @db.Decimal(12, 2)
  paidAmount       Decimal               @default(0) @map("paid_amount") @db.Decimal(12, 2)

  note             String?
  createdBy        String?               @map("created_by") @db.Uuid

  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")
  deletedAt        DateTime?             @map("deleted_at")

  supplier         Supplier              @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  purchaseOrder    SupplierPurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)

  items            SupplierInvoiceItem[]
  payments         SupplierPayment[]
  returns          SupplierPurchaseReturn[]

  @@unique([businessId, invoiceNo])
  @@index([businessId])
  @@index([supplierId])
  @@index([purchaseOrderId])
  @@index([status])
  @@index([invoiceDate])
  @@index([dueDate])
  @@map("supplier_invoices")
}

model SupplierInvoiceItem {
  id                String   @id @default(uuid()) @db.Uuid
  supplierInvoiceId String   @map("supplier_invoice_id") @db.Uuid
  productId         String   @map("product_id") @db.Uuid
  variantId         String?  @map("variant_id") @db.Uuid

  quantity          Decimal  @db.Decimal(14, 3)
  unitCost          Decimal  @map("unit_cost") @db.Decimal(12, 2)
  discountAmount    Decimal  @default(0) @map("discount_amount") @db.Decimal(12, 2)
  taxAmount         Decimal  @default(0) @map("tax_amount") @db.Decimal(12, 2)
  lineTotal         Decimal  @map("line_total") @db.Decimal(12, 2)

  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  supplierInvoice   SupplierInvoice @relation(fields: [supplierInvoiceId], references: [id], onDelete: Cascade)

  @@index([supplierInvoiceId])
  @@index([productId])
  @@index([variantId])
  @@map("supplier_invoice_items")
}

model SupplierPayment {
  id                String                @id @default(uuid()) @db.Uuid
  businessId         String                @map("business_id") @db.Uuid
  supplierId         String                @map("supplier_id") @db.Uuid
  supplierInvoiceId  String                @map("supplier_invoice_id") @db.Uuid

  paymentNo          String                @map("payment_no") @db.VarChar(100)
  amount             Decimal               @db.Decimal(12, 2)
  paymentDate        DateTime              @map("payment_date")
  paymentMethod      SupplierPaymentMethod @map("payment_method")
  referenceNo        String?               @map("reference_no") @db.VarChar(150)
  note               String?

  createdBy          String?               @map("created_by") @db.Uuid
  createdAt          DateTime              @default(now()) @map("created_at")
  updatedAt          DateTime              @updatedAt @map("updated_at")
  deletedAt          DateTime?             @map("deleted_at")

  supplier           Supplier              @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  supplierInvoice    SupplierInvoice       @relation(fields: [supplierInvoiceId], references: [id], onDelete: Restrict)

  @@unique([businessId, paymentNo])
  @@index([businessId])
  @@index([supplierId])
  @@index([supplierInvoiceId])
  @@index([paymentDate])
  @@map("supplier_payments")
}

model SupplierPurchaseReturn {
  id                String                       @id @default(uuid()) @db.Uuid
  businessId         String                       @map("business_id") @db.Uuid
  supplierId         String                       @map("supplier_id") @db.Uuid
  purchaseOrderId    String?                      @map("purchase_order_id") @db.Uuid
  supplierInvoiceId  String?                      @map("supplier_invoice_id") @db.Uuid
  locationId         String                       @map("location_id") @db.Uuid

  returnNo           String                       @map("return_no") @db.VarChar(100)
  returnDate         DateTime                     @map("return_date")
  status             SupplierPurchaseReturnStatus @default(DRAFT)
  reason             String?
  totalAmount        Decimal                      @default(0) @map("total_amount") @db.Decimal(12, 2)

  createdBy          String?                      @map("created_by") @db.Uuid
  createdAt          DateTime                     @default(now()) @map("created_at")
  updatedAt          DateTime                     @updatedAt @map("updated_at")

  supplier           Supplier                     @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  purchaseOrder      SupplierPurchaseOrder?        @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  supplierInvoice    SupplierInvoice?              @relation(fields: [supplierInvoiceId], references: [id], onDelete: SetNull)

  items              SupplierPurchaseReturnItem[]

  @@unique([businessId, returnNo])
  @@index([businessId])
  @@index([supplierId])
  @@index([purchaseOrderId])
  @@index([supplierInvoiceId])
  @@index([locationId])
  @@index([status])
  @@index([returnDate])
  @@map("supplier_purchase_returns")
}

model SupplierPurchaseReturnItem {
  id               String   @id @default(uuid()) @db.Uuid
  purchaseReturnId String   @map("purchase_return_id") @db.Uuid
  productId        String   @map("product_id") @db.Uuid
  variantId        String?  @map("variant_id") @db.Uuid

  quantity         Decimal  @db.Decimal(14, 3)
  unitCost         Decimal  @map("unit_cost") @db.Decimal(12, 2)
  lineTotal        Decimal  @map("line_total") @db.Decimal(12, 2)
  reason           String?

  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  purchaseReturn   SupplierPurchaseReturn @relation(fields: [purchaseReturnId], references: [id], onDelete: Cascade)

  @@index([purchaseReturnId])
  @@index([productId])
  @@index([variantId])
  @@map("supplier_purchase_return_items")
}