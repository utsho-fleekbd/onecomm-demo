// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum StoreStatus {
  ACTIVE
  INACTIVE
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  DRAFT
}

enum PlatformRole {
  SUPER_ADMIN
  ADMIN
  USER
}

enum StoreMemberStatus {
  ACTIVE
  INACTIVE
  INVITED
  SUSPENDED
}

enum ModuleAction {
  CREATE
  READ
  UPDATE
  DELETE
}

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String

  role   PlatformRole @default(USER)
  status UserStatus   @default(ACTIVE)

  ownedStores Store[]       @relation("StoreOwner")
  memberships StoreMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Store {
  id      String @id @default(uuid())
  ownerId String

  owner User @relation("StoreOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  name    String
  slug    String
  phone   String?
  address String?
  status  StoreStatus @default(ACTIVE)

  roles      Role[]
  members    StoreMember[]
  categories Category[]
  products   Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ownerId, slug])
  @@index([ownerId])
  @@map("stores")
}

model StoreMember {
  id String @id @default(uuid())

  storeId String
  userId  String

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  status StoreMemberStatus @default(ACTIVE)

  roles StoreMemberRole[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, userId])
  @@unique([id, storeId])
  @@index([userId])
  @@index([storeId])
  @@map("store_members")
}

model Role {
  id String @id @default(uuid())

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  name        String
  description String?
  isSystem    Boolean @default(false)

  members     StoreMemberRole[]
  permissions RolePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, name])
  @@unique([id, storeId])
  @@index([storeId])
  @@map("roles")
}

model StoreMemberRole {
  storeMemberId String
  roleId        String
  storeId       String

  storeMember StoreMember @relation(fields: [storeMemberId, storeId], references: [id, storeId], onDelete: Cascade)
  role        Role        @relation(fields: [roleId, storeId], references: [id, storeId], onDelete: Cascade)

  @@id([storeMemberId, roleId])
  @@index([storeId])
  @@index([roleId])
  @@map("store_member_roles")
}

model Module {
  id String @id @default(uuid())

  name String @unique

  permissions Permission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("modules")
}

model Permission {
  id String @id @default(uuid())

  moduleId String
  module   Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  action ModuleAction

  key String @unique

  roles RolePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([moduleId, action])
  @@index([moduleId])
  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model Category {
  id      String @id @default(uuid())
  storeId String

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  name     String
  slug     String
  parentId String?

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, slug])
  @@index([storeId])
  @@index([parentId])
  @@map("categories")
}

model Product {
  id         String  @id @default(uuid())
  storeId    String
  categoryId String?

  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  name        String
  slug        String
  sku         String?
  description String?

  price Decimal @db.Decimal(12, 2)

  status ProductStatus @default(DRAFT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, slug])
  @@unique([storeId, sku])
  @@index([storeId])
  @@index([categoryId])
  @@map("products")
}
